rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Explicit security rules for new feature
    match /users/{userId}/devices/{deviceId} {
      allow create: if request.resource.data.keys().hasAll(['token', 'createdAt', 'platform', 'uid'])
                    && request.resource.data.token is string
                    && request.resource.data.token.size() > 0
                    && request.resource.data.platform in ['web']
                    && request.resource.data.uid == userId;
      
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['token', 'createdAt', 'platform', 'uid'])
                    || request.resource.data.token == resource.data.token;

      allow read: if false;
    }
  }
}
