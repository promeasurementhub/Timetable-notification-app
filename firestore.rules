rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    
    match /devices/{deviceId} {
      // Allow any device to register its token
      allow create: if request.resource.data.keys().hasAll(['token', 'createdAt', 'platform'])
                    && request.resource.data.token is string
                    && request.resource.data.token.size() > 0
                    && request.resource.data.platform in ['web'];
      
      // Allow them to update their own token doc
      allow update: if request.resource.data.token == resource.data.token;
      
      allow read: if false; // Only backend can read tokens to send push
    }
  }
}
